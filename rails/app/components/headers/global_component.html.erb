<header class="flex items-center gap-2 px-2">
  <div class="w-[32px] flex-none">
    <button
      type="button"
      onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))"
      class="btn-sm-icon-ghost rounded-full"
      aria-label="<%= t('nouns.menu') %>"
    >
      <%= render BaseUI::IconComponent.new(name: "sidebar-simple-regular", size: "24px", class_name: "fill-base-content") %>
    </button>
  </div>

  <div class="flex-1">
    <div class="mx-auto w-fit">
      <%= breadcrumb %>
    </div>
  </div>

  <div class="w-[32px] flex-none">
  </div>
</header>
