<div
  data-controller="global-hotkey"
  data-global-hotkey-search-path-target="searchPath"
  <%= "data-global-hotkey-current-space-identifier-value=\"#{current_space.identifier}\"".html_safe if current_space %>
>
  <% if show_sidebar? %>
    <%= render SidebarComponent.new(current_page_name:, current_user:, current_space:) %>
  <% end %>

  <div class="bg-background min-h-screen">
    <meta name="search-path" content="<%= search_path %>" data-global-hotkey-target="searchPath">

    <div class="flex flex-col gap-4 py-4">
      <%= header %>

      <%= main %>

      <% if footer? %>
        <%= footer %>
      <% end %>
    </div>
  </div>

  <div class="fixed bottom-2 left-1/2 z-50 flex w-full translate-x-[-50%] flex-col items-center gap-4 px-2">
    <%= render BaseUI::Toasts::FlashComponent.new(flash:) %>

    <% if show_bottom_navbar? %>
      <%= render Navbars::BottomComponent.new(current_page_name:, current_user:, current_space:) %>
    <% end %>
  </div>
</div>
